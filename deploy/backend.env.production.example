# 複製成 Pi 上的 backend/.env，並填入實際值。
# 產生 SECRET_KEY： openssl rand -hex 32

SECRET_KEY=請換成-openssl-rand-hex-32-的長隨機字串
FRONTEND_ORIGIN=https://psyche-test.com
DATABASE_URL=sqlite:////home/keye/webapp/backend/personality_paradox.db
GEMINI_API_KEY=填入你的-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT=60
SESSION_MAX_AGE=7200
# 正式機走 HTTPS，開啟 cookie Secure 旗標
COOKIE_SECURE=true
